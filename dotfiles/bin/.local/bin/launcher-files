#!/usr/bin/env bash
set -euo pipefail

dir="${1:-$HOME}"
editor="${EDITOR:-nvim}"

file="$(
  fd . "$dir" \
    --type f \
    --hidden \
    --follow \
    --exclude .git \
    --exclude node_modules \
    --exclude .cache \
  | sed "s|^$HOME|~|" \
  | fuzzel --dmenu --prompt='❯ file '
)"

[ -n "${file:-}" ] || exit 0

file="${file/#\~/$HOME}"

#xdg-open "$file" >/dev/null 2>&1 &
ghostty -e "$editor" "$file" > /dev/null 2&1 &
