#!/usr/bin/env bash
set -euo pipefail

title="${1:-OSD}"
value="${2:-0}"
icon="${3:-}"
timeout=1000

# 10-block progress bar
filled=$(((value + 5) / 10))
bar="$(printf '█%.0s' $(seq 1 "$filled"))"
# bar=$(printf "%-${filled}s" "" | tr ' ' '█')

notify-send \
  -a "Void Neon" \
  -r 91190 \
  -t 1000 \
  -h string:x-canonical-private-synchronous:osd \
  -t ${timeout} \
  "${icon} ${bar} ${value}%" \
  ""
