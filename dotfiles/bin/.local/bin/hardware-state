#!/usr/bin/env bash
set -euo pipefail

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/void-neon"
ac_state_file="$state_dir/hardware-ac.env"
battery_state_file="$state_dir/hardware-battery.env"

mkdir -p "$state_dir"

power_source() {
  local supply type online

  for supply in /sys/class/power_supply/*; do
    [[ -d "$supply" ]] || continue
    [[ -r "$supply/type" ]] || continue

    type="$(cat "$supply/type")"

    case "$type" in
      Mains|USB|USB_C|USB_PD)
        online="$supply/online"
        if [[ -r "$online" && "$(cat "$online")" == "1" ]]; then
          printf 'ac\n'
          return
        fi
        ;;
    esac
  done

  printf 'battery\n'
}

state_file_for_power() {
  case "${1:?power source required}" in
    ac) printf '%s\n' "$ac_state_file" ;;
    battery) printf '%s\n' "$battery_state_file" ;;
    *) exit 2 ;;
  esac
}

state_file_for_current_power() {
  state_file_for_power "$(power_source)"
}

get_volume() {
  local value

  value="$(
    wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null |
      awk '{ print int($2 * 100) }'
  )" || return 1

  [[ "$value" =~ ^[0-9]+$ ]] || return 1

  printf '%s\n' "$value"
}

get_screen_brightness() {
  brightnessctl -m |
    cut -d, -f4 |
    tr -d '%'
}

kbd_device() {
  brightnessctl --list 2>/dev/null |
    awk -F"'" '/kbd_backlight/ { print $2; exit }'
}

get_keyboard_brightness() {
  local dev
  dev="$(kbd_device)"

  [[ -n "$dev" ]] || return 0

  brightnessctl --device="$dev" -m |
    cut -d, -f4 |
    tr -d '%'
}

set_keyboard_brightness() {
  local value="${1:?value required}"
  local dev

  dev="$(kbd_device)"
  [[ -n "$dev" ]] || return 0

  brightnessctl --device="$dev" set "${value}%"
}

get_power_profile() {
  powerprofilesctl get
}

set_power_profile() {
  local profile="${1:?profile required}"
  local user="${VOID_NEON_USER:-gene}"
  echo "In set_power_profile before original" >> /tmp/hardware-save.log
  # powerprofilesctl set "$profile" >> /tmp/hardware-save.log 2>&1

  echo "In set_power_profile" >> /tmp/hardware-save.log
  sudo -u "$user" powerprofilesctl set "$profile" >> /tmp/hardware-save.log 2>&1
}

save() {
  local source file kbd

  source="$(power_source)"
  file="$(state_file_for_power "$source")"
  brightness="$(get_screen_brightness || true)"
  kbd="$(get_keyboard_brightness || true)"
  power_profile="$(get_power_profile || true)"

  {
    [[ -n "$brightness" ]] && printf 'BRIGHTNESS=%q\n' "$brightness"
    [[ -n "$kbd" ]] && printf 'KBD_BRIGHTNESS=%q\n' "$kbd"
    [[ -n "$power_profile" ]] && printf 'POWER_PROFILE=%q\n' "$power_profile"

    if volume="$(get_volume)"; then
      printf 'VOLUME=%q\n' "$volume"
    fi
  } > "$file"
}

restore_file() {
  local file="${1:?state file required}"
  local restore_volume="${2:-yes}"

  [[ -f "$file" ]] || exit 0

  # shellcheck disable=SC1090
  source "$file"

  echo "restore_file: If restore_volume" >> /tmp/hardware-save.log
  if [[ "$restore_volume" == "yes" && -n "${VOLUME:-}" ]]; then
    wpctl set-volume @DEFAULT_AUDIO_SINK@ "${VOLUME}%"
  fi

  echo "restore_file: If brightness" >> /tmp/hardware-save.log
  if [[ -n "${BRIGHTNESS:-}" ]]; then
    brightnessctl set "${BRIGHTNESS}%"
  fi

  echo "restore_file: If kbd_brightness" >> /tmp/hardware-save.log
  if [[ -n "${KBD_BRIGHTNESS:-}" ]]; then
    set_keyboard_brightness "$KBD_BRIGHTNESS"
  fi

  echo "restore_file: If power_profile" >> /tmp/hardware-save.log
  if [[ -n "${POWER_PROFILE:-}" ]]; then
    echo "restore_file: Before set_power_profile" >> /tmp/hardware-save.log
    set_power_profile "$POWER_PROFILE"
    echo "restore_file: After set_power_profile" >> /tmp/hardware-save.log
  fi
}

restore_current() {
  restore_file "$(state_file_for_current_power)" yes
}

refresh_waybar() {
    local cmd="$HOME/.local/bin/waybar-refresh"

    [[ -x "$cmd" ]] || return 0

    "$cmd"
}

power_event() {
  # Tiny delay lets sysfs settle after plug/unplug.
  sleep 0.5
  # restore_current
  restore_file "$(state_file_for_current_power)" no
  sleep 0.5
  # refresh_waybar
  refresh_waybar >> /tmp/hardware-save.log 2>&1
}

case "${1:-}" in
  save)
    save
    ;;

  restore)
    restore_current
    ;;

  power-event)
    echo "PATH=[$PATH]" >> /tmp/hardware-save.log
    echo "HOME=[$HOME]" >> /tmp/hardware-save.log
    power_event
    ;;

  power-source)
    power_source
    ;;

  *)
    printf 'usage: hardware-state save|restore|restore-current|power-event|power-source\n' >&2
    exit 2
    ;;
esac
